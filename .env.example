# Kipu — plantilla de variables de entorno para producción
# Copia a .env y rellena con tus secretos reales. NO commits .env al repo.
# ==============================================================================

# ── Supabase (base de datos + auth) ───────────────────────────────────────────
SUPABASE_URL=https://<tu-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service role key — NO la anon key>

# ── JWT (sesiones del dashboard) ──────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=<cadena aleatoria larga>

# ── Puerto interno de la app (nginx proxea → este puerto) ─────────────────────
DASHBOARD_PORT=3009

# ── Modo desarrollo ────────────────────────────────────────────────────────────
# EN PRODUCCIÓN DEBE SER false. En true, cualquier request entra como el primer
# usuario de la BD — fuga de datos entre tenants.
DEV_BYPASS=false

# ── IA proveedores ────────────────────────────────────────────────────────────
GOOGLE_API_KEY=<Google Generative AI API key (Gemini)>
OPENAI_API_KEY=<OpenAI API key>

# ── Google Sign-In (login/registro con cuenta de Google) ──────────────────────
# OAuth 2.0 Client ID (tipo "Web application") creado en:
#   https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins:
#   - http://localhost:3009  (dev)
#   - http://localhost:8080  (dev — http-server del dashboard)
#   - https://qatu.ai     (prod)
# Sin secret: usamos el flujo de id_token (GIS) verificado vía tokeninfo.
GOOGLE_CLIENT_ID=<OAuth 2.0 Client ID (.apps.googleusercontent.com)>

# ── Base URL pública (OAuth callbacks y webhooks) ─────────────────────────────
# Debe apuntar al dominio público con HTTPS. Sin slash final.
WEBHOOK_BASE_URL=https://qatu.ai

# ── Meta / Instagram (OAuth + webhook) ────────────────────────────────────────
# Registrar callback en Meta Developers:
#   ${WEBHOOK_BASE_URL}/api/auth/instagram/callback
# IMPORTANTE: META_APP_SECRET y META_VERIFY_TOKEN son COMPARTIDOS entre
# Instagram, TikTok via Meta, y el webhook de WhatsApp Cloud API (abajo).
# Una misma Meta App puede subscribir múltiples productos — usa los mismos
# valores en /api/webhook/meta y /api/webhook/instagram.
META_APP_ID=<Meta App ID>
META_APP_SECRET=<Meta App Secret>
META_CLIENT_TOKEN=<Meta Client Token>
META_VERIFY_TOKEN=<cualquier cadena fija, debe coincidir con la config de webhook>

# ── Meta Cloud API · WhatsApp Business Platform (OFICIAL) ─────────────────────
# Provider alternativo a Baileys. Cuando bot.messagingProvider = 'meta', el
# send/receive va por graph.facebook.com en vez del socket Baileys.
# Setup en Meta Developers:
#   1. App → Add product → WhatsApp
#   2. Configuration → Webhook → Callback URL:
#        ${WEBHOOK_BASE_URL}/api/webhook/meta
#      Verify token: el valor de META_VERIFY_TOKEN (arriba).
#   3. Subscribe to field: `messages`
#   4. Crear System User en Business Manager con scope `whatsapp_business_messaging`
#      y generar token PERMANENTE (no el de 24h del playground).
#   5. En el dashboard de Qatu, abrir "Conexiones" → "Conectar Meta Cloud API"
#      y pegar phoneNumberId + accessToken del System User.
META_GRAPH_VERSION=v21.0

# ── TikTok (OAuth + webhook) ──────────────────────────────────────────────────
# Registrar callback en TikTok for Developers:
#   ${WEBHOOK_BASE_URL}/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=<TikTok Client Key>
TIKTOK_CLIENT_SECRET=<TikTok Client Secret>
TIKTOK_VERIFY_TOKEN=<cualquier cadena fija, debe coincidir con la config de webhook>

# ── ManyChat (API key para DMs de IG/TikTok) ──────────────────────────────────
MANYCHAT_API_KEY=<ManyChat API key>

# ── Apify (enriquecimiento de leads desde WhatsApp) ───────────────────────────
APIFY_API_TOKEN=<Apify API token>

# ── Opcional ──────────────────────────────────────────────────────────────────
MAYA=<override opcional — dejar vacío salvo debug>
